---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagChips from '../components/TagChips.astro';
import OutcomeBadge from '../components/OutcomeBadge.astro';
import config from '../config';
import { getCollection, getEntry } from 'astro:content';

const allPosts = await getCollection('writing');
const aboutPage = await getEntry('pages', 'about');

const sorted = allPosts.sort((a, b) => {
  const aDate = a.data.type === 'decision' ? a.data.date : a.data.last_updated;
  const bDate = b.data.type === 'decision' ? b.data.date : b.data.last_updated;
  return bDate.getTime() - aDate.getTime();
});

const { headline, intro } = aboutPage.data;

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title={config.site.name} description={config.site.description}>
  {(headline || intro) && (
    <div class="home-intro">
      {headline && <h1>{headline}</h1>}
      {intro && <p>{intro}</p>}
    </div>
  )}

  <ul class="writing-list">
    {sorted.map(post => (
      <li class="writing-item">
        <TagChips tags={post.data.type === 'decision' ? post.data.tags : []} type={post.data.type} />
        <p class="writing-item-title">
          <a href={`/writing/${post.id}`}>{post.data.title}</a>
        </p>
        <p class="writing-item-meta">
          {post.data.type === 'decision'
            ? <>{formatDate(post.data.date)} · {post.data.reading_time}</>
            : <>started {formatDate(post.data.started)} · updated {formatDate(post.data.last_updated)}</>}
        </p>
        <p class="writing-item-excerpt">
          {post.data.type === 'decision' ? post.data.outcome : post.data.summary}
        </p>
        {post.data.type === 'decision' && (
          <OutcomeBadge outcome={post.data.outcome} outcome_status={post.data.outcome_status} />
        )}
      </li>
    ))}
  </ul>
</BaseLayout>
